{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__atlassian__updateJiraIssue|mcp__atlassian__addCommentToJiraIssue",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/require-review.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/enrichment-completeness.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/disposition-guard.sh", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__perplexity__perplexity_search|mcp__perplexity__perplexity_ask|mcp__perplexity__perplexity_reason|mcp__perplexity__perplexity_research",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bias-check-reminder.sh", "timeout": 5 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/handoff-validator.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
